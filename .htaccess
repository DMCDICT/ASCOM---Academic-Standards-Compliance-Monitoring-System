Options -Indexes

<FilesMatch "\.(sql|md|bat|log)$">
    Require all denied
</FilesMatch>

# Allow specific API files
<FilesMatch "^(add_term|add_school_year|add_holiday|get_school_year_events|get_all_terms|delete_term)\.php$">
    Require all granted
</FilesMatch>

# Block dangerous patterns
<FilesMatch "^(test_|debug_|check_|fix_|setup_|cleanup_|assign_test_|simple_user_check|database_manager|create_|force_|reset_).*$">
    Require all denied
</FilesMatch>
