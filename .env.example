
# Application Configuration
# ============================================================
APP_NAME="ASCOM System"
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost:8080

APP_KEY=
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_TIMEZONE=Asia/Manila
APP_CHARSET=UTF-8

# Session Configuration
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=

# Cache Configuration
CACHE_DRIVER=redis
CACHE_PREFIX=ascom_cache_

# Queue Configuration
QUEUE_CONNECTION=redis
QUEUE_FAILED_TABLE=failed_jobs

# ============================================================
# Database Configuration
# ============================================================
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=ascom_db
DB_USERNAME=ascom_user
DB_PASSWORD=ascom_password_secure_123
DB_SOCKET=

# Database Options (for older MySQL/MariaDB)
DB_OPTIONS="--default-authentication-plugin=mysql_native_password"

# Testing Database
DB_TEST_CONNECTION=sqlite
DB_TEST_DATABASE=:memory:

# ============================================================
# Redis Configuration
# ============================================================
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Redis Cache
CACHE_STORE=redis
REDIS_CACHE_DB=0

# Redis Queue
REDIS_QUEUE_DB=1

# Redis Session
REDIS_SESSION_DB=2

# ============================================================
# File Storage Configuration
# ============================================================
FILESYSTEM_DISK=local

# ============================================================
# Security Configuration
# ============================================================
SANCTUM_STATEFUL_DOMAINS=localhost:8080,localhost:3000

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://localhost:3000
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Authorization,Content-Type,X-Requested-With,X-XSRF-TOKEN

# Session Security
SESSION_COOKIE=ascom_session
SESSION_SAME_SITE=lax

# CSRF Token
CSRF_TOKEN_NAME=_token

# ============================================================
# Rate Limiting Configuration
# ============================================================
RATE_LIMITER_MAX_ATTEMPTS=60
RATE_LIMITER_DECAY_MINUTES=1

# Auth Rate Limits
AUTH_LOGIN_MAX_ATTEMPTS=5
AUTH_LOCKOUT_MINUTES=15

# API Rate Limits
API_RATE_LIMIT=60
API_RATE_LIMIT_PERIOD=1

# ============================================================
# Authentication Configuration
# ============================================================
AUTH_PASSWORD_TIMEOUT_MINUTES=15
AUTH_LOGOUT_OTHER_DEVICES=true
AUTH_PASSWORD_HISTORY_COUNT=5

# Two-Factor Authentication (Future)
TWO_FACTOR_ENABLED=false

# ============================================================
# Logging Configuration
# ============================================================
LOG_CHANNEL=stack
LOG_STACK=single,daily
LOG_LEVEL=debug
LOG_DEPRECATIONS_CHANNEL=null

# Log Channels
LOG_SINGLE_PATH=/var/www/html/storage/logs/laravel.log
LOG_DAILY_PATH=/var/www/html/storage/logs/daily
LOG_SYSLOG_IDENTIFIER=ascom

# ============================================================
# Monitoring & Debugging (Development)
# ============================================================

DEBUGBAR_ENABLED=true
TELESCOPE_ENABLED=true

# Xdebug Configuration
XDEBUG_MODE=develop,debug
XDEBUG_CLIENT_HOST=host.docker.internal
XDEBUG_CLIENT_PORT=9003

# ============================================================
# Real-time Notifications (Socket.IO)
# ============================================================
# Self-hosted WebSocket server for real-time notifications
# Eliminates need for external services like Pusher
SOCKETIO_HOST=localhost
SOCKETIO_PORT=3001
SOCKETIO_PATH=/socket.io
SOCKETIO_NAMESPACES=/notifications,/messages

# Socket.IO Redis Adapter (for scaling)
SOCKETIO_REDIS_HOST=redis
SOCKETIO_REDIS_PORT=6379
SOCKETIO_REDIS_DB=3

# Debug
SOCKETIO_DEBUG=false

# ============================================================
# Feature Flags (Future Features)
# ============================================================
FEATURES_TWO_FACTOR=false
FEATURES_DOCUMENT_UPLOAD=true
FEATURES_EXPORT_EXCEL=true
FEATURES_EXPORT_PDF=true
FEATURES_ACTIVITY_LOG=true

# ============================================================
# Import/Export Configuration
# ============================================================
IMPORT_MAX_ROWS=5000
IMPORT_TIMEOUT_SECONDS=300

EXCEL_EXPORT_MAX_ROWS=10000
PDF_PAGE_SIZE=A4
PDF_ORIENTATION=portrait

# ============================================================
# Custom ASCOM Application Settings
# ============================================================

# School/Institution Settings
SCHOOL_NAME="Academic Institution"
SCHOOL_CODE=ASC
SCHOOL_YEAR_START_MONTH=8

# User Roles Configuration
ROLE_DEFAULT_USER=faculty
ROLE_DEFAULT_ADMIN=super_admin

# Session Timeout (minutes)
SESSION_TIMEOUT=120
SESSION_IDLE_TIMEOUT=30

# Password Requirements
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBER=true
PASSWORD_REQUIRE_SPECIAL=true

# Captcha Configuration
CAPTCHA_ENABLED=true
CAPTCHA_DIFFICULTY=medium

# Compliance Settings
COMPLIANCE_APPROVAL_WORKFLOW=true

# ============================================================
# Docker-Specific Configuration
# ============================================================
DOCKER_ENV=true
CONTAINER_NAME=ascom_app
DOCKER_NETWORK=ascom-backend

# ============================================================
# Development Tools
# ============================================================
NODE_ENV=development
VITE_DEV_HOST=0.0.0.0
VITE_DEV_PORT=3000

# ============================================================
# Backup Configuration
# ============================================================
BACKUP_ENABLED=true
BACKUP_SCHEDULE="0 2 * * *"
BACKUP_RETENTION_DAYS=30
BACKUP_PATH=/var/www/html/storage/backups
